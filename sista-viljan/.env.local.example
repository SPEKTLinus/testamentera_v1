# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: required for per-phone will-start limits (see supabase/migrations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Max times a phone number may start the will flow (abuse limit). Default 10 if unset.
MAX_WILLS_PER_PHONE=10

# Server-only: sign bearer tokens after phone gate so AI routes (/api/will-chat, letter-chat, generate-will)
# cannot be called with only a forged client utkast. Use a long random string (e.g. openssl rand -hex 32).
# If unset, only format-check on verifiedPhone + per-IP rate limits apply (weaker).
WILL_ACCESS_SECRET=
# Optional token lifetime in ms (default 7 days).
# WILL_ACCESS_TTL_MS=604800000

# Optional per-IP rate limits (sliding window, per server instance). Defaults shown.
# API_RATE_LIMIT_AI_MAX=45
# API_RATE_LIMIT_AI_WINDOW_MS=60000
# API_RATE_LIMIT_START_WILL_MAX=20
# API_RATE_LIMIT_START_WILL_WINDOW_MS=60000
# API_RATE_LIMIT_CLAUDE_MAX=25
# API_RATE_LIMIT_CLAUDE_WINDOW_MS=60000

# Anthropic (Claude API) — krävs för /api/will-chat och /api/generate-will (lägg samma nyckel i Vercel → Settings → Environment Variables)
ANTHROPIC_API_KEY=sk-ant-...

# Will-chat före köp: max summan input+output tokens (Anthropic) per obetalt utkast — motsvarar er faktiska kostnad, inte Unicode-tecken i chatten (standard 105 000).
# WILL_CHAT_SESSION_MAX_TOKENS=105000
# Äldre alias (om satt och MAX_TOKENS saknas): WILL_CHAT_SESSION_TOKEN_BUDGET
# WILL_CHAT_SESSION_SOFT_FRACTION=0.85
# WILL_CHAT_SESSION_STRONG_GUIDANCE_FRACTION=0.95
#
# Global pool i Supabase: första start per nytt mobilnummer drar 1; varje betalt testamente (Swish-callback) adderar N (standard 25). Se migration will_free_start_pool.
# WILL_FREE_SLOTS_PER_WILL_PURCHASE=25

# Swish Handel API
SWISH_MERCHANT_NUMBER=1234567890
SWISH_CERTIFICATE=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
SWISH_CERTIFICATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Resend (email) — kvitto via /api/send-purchase-receipt, påminnelser m.m.
RESEND_API_KEY=re_...
# Valfri avsändaradress (måste vara verifierad domän i Resend). Standard: Sista Viljan <hej@sistaviljan.se>
# RESEND_FROM="Sista Viljan <noreply@dinverifieradedoman.se>"

# Reminder cron secret — set to any random string, use same in Supabase pg_cron job
REMINDER_SECRET=your-secret-here

# App URL (used in reminder emails and Swish callbacks)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
